# Keep the build context small and reproducible.
.git
.venv
venv
__pycache__
*.py[cod]
*.egg-info
build
dist
.pytest_cache
.idea
.vscode

# Local-only / large / secret — never send to the build
.env
.jarvis/state
*.mp4
*.mov
tests
# NOTE: jarvis-voice.wav IS sent to the build (baked into the image) so the cloned voice works
# for ANY mounted project, not only the jarvis repo. Keep the image + repo private.
